# ========================================================
# FloraMetrics AI - Variables de Entorno (Configuración del Negocio)
# ========================================================

# 1. API Key central de Google Gemini Vision AI
# Consíguela gratis en: https://aistudio.google.com/
VITE_GEMINI_API_KEY=tu_clave_aqui_AIzaSy...

# 2. Configuración de Supabase (Base de Datos & Autenticación de Usuarios)
# Consíguelos en: https://supabase.com/
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_clave_anon_supabase

# 3. Configuración de Cloudinary (Almacenamiento de Fotos en la Nube)
# Consíguelo en: https://cloudinary.com/
VITE_CLOUDINARY_CLOUD_NAME=tu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=tu_preset
